# Edge Function secrets — template.
#
# These keys live ONLY server-side. They are NEVER bundled into the Flutter
# client (which holds only the Supabase URL + anon key).
#
# Local development:
#   1. Copy this file to supabase/functions/.env and fill in real values.
#   2. supabase functions serve --env-file supabase/functions/.env
#
# Hosted deployment (do NOT put real values in this file):
#   supabase secrets set ANTHROPIC_API_KEY=...        --project-ref <ref>
#   supabase secrets set GOOGLE_PLACES_API_KEY=...    --project-ref <ref>
#   supabase secrets set SEARCH_API_KEY=...           --project-ref <ref>

# Vision + text model (menu parsing in Session 3, estimation in Session 6)
ANTHROPIC_API_KEY=

# Google Places (restaurant resolution in Session 2)
GOOGLE_PLACES_API_KEY=

# Web search / retrieval mechanism (menu acquisition in Session 3)
SEARCH_API_KEY=
